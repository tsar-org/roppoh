{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["src", "./*.ts"],
      "outputs": ["build/**"]
    },
    "cf-typegen": {
      "inputs": ["wrangler.jsonc", ".dev.vars"],
      "outputs": ["worker-configuration.d.ts"]
    },
    "type-check": {
      "inputs": ["src", "test", "$TURBO_ROOT$/tsconfig.json", "./*.ts", "./tsconfig.json"],
      "outputs": [".react-router/types/**"]
    }
  }
}
