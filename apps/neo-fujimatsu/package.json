{
  "name": "@roppoh/neo-fujimatsu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server/entry.ts",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types  --strict-vars=false",
    "type-check": "tsc --noEmit",
    "dev": "bun run reset:wrangler && bun run migration && bun vite dev",
    "migration": "printf \"y\\n\" | wrangler d1 migrations apply roppoh-better-auth --local",
    "reset:wrangler": "rm -rf .wrangler",
    "test:e2e": "vitest run",
    "test:vrt": "playwright test"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "1.6.2",
    "@better-auth/passkey": "catalog:",
    "@roppoh/better-auth": "workspace:*",
    "@roppoh/shadcn": "workspace:*",
    "@tanstack/react-query": "5.99.0",
    "better-auth": "1.5.6",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.10",
    "jotai": "2.19.1",
    "lucide-react": "1.8.0",
    "nuqs": "2.8.9",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "7.14.0",
    "sonner": "catalog:",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/vitest-pool-workers": "0.14.1",
    "@playwright/test": "1.56.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "5.2.0",
    "cloudflare": "5.2.0",
    "msw": "2.13.3",
    "playwright-msw": "3.0.1",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.2",
    "wrangler": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
