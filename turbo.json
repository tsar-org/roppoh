{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "cf-typegen": {
      "cache": true,
      "dependsOn": ["^cf-typegen"],
      "outputs": ["worker-configuration.d.ts"]
    },
    "type-check": {
      "cache": true,
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false
    }
  }
}
