{
  "name": "@roppoh/better-auth",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "generate:migration": "drizzle-kit generate --config='./drizzle.config.ts'",
    "generate:schema": "bun x @better-auth/cli generate --config='./src/auth.ts' --output='./src/auth-schema.ts' --yes"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.5.6",
    "@better-auth/oauth-provider": "1.5.6",
    "@better-auth/passkey": "catalog:",
    "drizzle-orm": "0.44.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260401.1",
    "drizzle-kit": "catalog:"
  },
  "peerDependencies": {
    "better-auth": "1.5.6",
    "typescript": "catalog:"
  }
}
