{
  "name": "@roppoh/better-auth",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "generate:migration": "drizzle-kit generate --config='./drizzle.config.ts'",
    "generate:schema": "bun x @better-auth/cli generate --config='./src/auth.ts' --output='./src/auth-schema.ts' --yes"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251231.0",
    "drizzle-kit": "0.31.8"
  },
  "peerDependencies": {
    "better-auth": "^1.3.32",
    "typescript": "^5.0.0"
  }
}
