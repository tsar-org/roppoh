{
  "name": "@roppoh/better-auth-database",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "migration": "cli migrate --yes",
    "migration:generate": "cli generate --output src/migrations/00000000000000_better_auth_schema.sql --yes",
    "schema:generate": "drizzle-kit pull"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.3.34",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.4.1",
    "drizzle-kit": "^0.31.5"
  },
  "peerDependencies": {
    "better-auth": "^1.3.32",
    "typescript": "^5.0.0"
  }
}
