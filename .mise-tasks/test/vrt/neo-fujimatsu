#!/usr/bin/env bash
#MISE description="Run VRT for @roppoh/neo-fujimatsu"
#MISE depends=["test:vrt:build-container"]
#USAGE flag "-u --update-snapshots" help="Update VRT screenshots"

set -euo pipefail

IMAGE="roppoh-playwright:latest"

CMD="bun run --filter @roppoh/neo-fujimatsu test:vrt"
if [ "${usage_update_snapshots:-false}" = "true" ]; then
  CMD+=" -- --update-snapshots"
fi

docker run --rm \
  -v "$PWD/apps/neo-fujimatsu/test/vrt":/app/apps/neo-fujimatsu/test/vrt \
  "$IMAGE" \
  bash -c "$CMD"
